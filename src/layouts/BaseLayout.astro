---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href="https://sheepdogcyberdefense.com/">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sheepdogcyberdefense.com/">
  <meta name="twitter:card" content="summary_large_image">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sheepdog Cyber Defense",
    "legalName": "Sheepdog Cyber Defense LLC",
    "url": "https://sheepdogcyberdefense.com",
    "areaServed": {
      "@type": "State",
      "name": "Texas"
    },
    "serviceArea": ["Bulverde", "Spring Branch", "San Antonio"],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "sheepdogcyberdefense@protonmail.com",
      "contactType": "sales"
    }
  }
  </script>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo">SHEEPDOG CYBER DEFENSE</a>
      <ul>
        <li><a href="/services">Services</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; 2022 Sheepdog Cyber Defense LLC. All rights reserved.</p>
    <ul>
      <li><a href="/privacy">Privacy Policy</a></li>
    </ul>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #0f1419;
    --bg-alt: #1a1f26;
    --text: #e7e9ea;
    --text-muted: #8b98a5;
    --accent: #1d9bf0;
    --accent-hover: #1a8cd8;
    --border: #2f3336;
    --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  a {
    color: var(--accent);
    text-decoration: none;
  }
  
  a:hover {
    color: var(--accent-hover);
  }
  
  header {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
  }
  
  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    color: var(--text);
  }
  
  .logo:hover {
    color: var(--text);
  }
  
  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
  }
  
  nav a {
    color: var(--text-muted);
    font-weight: 500;
  }
  
  nav a:hover {
    color: var(--text);
  }
  
  main {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }
  
  footer {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
  }
  
  footer p {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  
  footer ul {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
  
  footer a {
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  h2 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }
  
  h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  
  p {
    margin-bottom: 1rem;
    color: var(--text-muted);
  }
  
  .btn {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-weight: 600;
    transition: background 0.2s;
  }
  
  .btn:hover {
    background: var(--accent-hover);
    color: white;
  }
</style>
