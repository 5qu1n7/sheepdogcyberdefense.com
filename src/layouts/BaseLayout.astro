---
const { title, description, showMatrix = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL.toString()}>
  <meta name="twitter:card" content="summary_large_image">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Sheepdog Cyber Defense",
    "legalName": "Sheepdog Cyber Defense LLC",
    "url": "https://sheepdogcyberdefense.com",
    "description": "Veteran-owned penetration testing and cybersecurity services for businesses in Bulverde, Spring Branch, San Antonio, and South Central Texas.",
    "telephone": "+1-830-123-4567",
    "email": "sheepdogcyberdefense@protonmail.com",
    "priceRange": "$$",
    "openingHours": "Mo-Fr 09:00-18:00",
    "areaServed": {
      "@type": "State",
      "name": "Texas"
    },
    "serviceArea": {
      "@type": "Place",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bulverde",
        "addressRegion": "TX",
        "addressCountry": "US"
      }
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bulverde",
      "addressRegion": "TX",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "29.8821",
      "longitude": "-98.4186"
    },
    "image": "https://sheepdogcyberdefense.com/images/logo.svg",
    "logo": "https://sheepdogcyberdefense.com/images/logo.svg",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "sheepdogcyberdefense@protonmail.com",
      "contactType": "sales",
      "availableLanguage": "English"
    },
    "sameAs": [
      "https://www.linkedin.com/company/sheepdogcyberdefense"
    ],
    "keywords": "penetration testing, cybersecurity, pentest, ethical hacking, security assessment, San Antonio, Bulverde, Spring Branch, Texas",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Security Services",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "External Penetration Testing", "description": "Testing of internet-facing systems and infrastructure"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Internal Penetration Testing", "description": "Assessment of internal network security and post-breach scenarios"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Web Application Penetration Testing", "description": "Security testing for websites and web applications"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Red Teaming", "description": "Full-scope realistic attack simulations"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Physical Site Review", "description": "Assessment of physical security controls"}}
      ]
    }
  }
  </script>
</head>
<body>
  {showMatrix && <canvas id="matrix-bg"></canvas>}
  <header>
    <nav>
      <a href="/" class="logo">
        <img src="/images/logo.svg" alt="Sheepdog Cyber Defense">
      </a>
      <ul>
        <li><a href="/services">Services</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <img src="https://tvc.texas.gov/wp-content/uploads/2025/04/VOB-Logo-wwatermark-2-300x300.jpg" alt="Veteran Owned Business" class="vob-logo">
    <p>&copy; 2022 - 2026 Sheepdog Cyber Defense LLC. All rights reserved.</p>
    <ul>
      <li><a href="/privacy">Privacy Policy</a></li>
    </ul>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #0f1419;
    --bg-alt: #1a1f26;
    --text: #e7e9ea;
    --text-muted: #8b98a5;
    --accent: #1d9bf0;
    --accent-hover: #1a8cd8;
    --border: #2f3336;
    --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  a {
    color: var(--accent);
    text-decoration: none;
  }
  
  a:hover {
    color: var(--accent-hover);
  }
  
  header {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    position: relative;
    z-index: 100;
  }
  
  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    display: flex;
    align-items: center;
  }
  
  .logo img {
    height: 80px;
    width: auto;
  }
  
  .logo:hover {
    color: var(--text);
  }
  
  nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
  }
  
  nav a {
    color: var(--text-muted);
    font-weight: 500;
  }
  
  nav a:hover {
    color: var(--text);
  }
  
  main {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }
  
  footer {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
  }
  
  .vob-logo {
    height: 80px;
    width: auto;
    margin-bottom: 1rem;
    border-radius: 4px;
  }
  
  footer p {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  
  footer ul {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
  
  footer a {
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }
  
  h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  
  p {
    margin-bottom: 1rem;
    color: var(--text-muted);
  }
  
  .btn {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-weight: 600;
    transition: background 0.2s;
  }
  
  .btn:hover {
    background: var(--accent-hover);
    color: white;
  }

  #matrix-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.15;
  }
  
  @media (max-width: 768px) {
    header {
      padding: 0.75rem 1rem;
    }
    
    .logo img {
      height: 50px;
    }
    
    nav ul {
      gap: 1rem;
    }
    
    nav a {
      font-size: 0.875rem;
    }
    
    main {
      padding: 2rem 1rem;
    }
    
    h1 {
      font-size: 1.75rem;
    }
    
    h2 {
      font-size: 1.25rem;
    }
    
    footer {
      padding: 1.5rem 1rem;
    }
    
    .vob-logo {
      height: 50px;
    }
  }
  
  @media (max-width: 480px) {
    nav ul {
      gap: 0.75rem;
    }
    
    nav a {
      font-size: 0.75rem;
    }
    
    h1 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  const canvas = document.getElementById('matrix-bg');
  if (!canvas) {
    // No matrix effect on this page
  } else {
    const ctx = canvas.getContext('2d');

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%^&*()_+-=[]{}|;:,.<>?';
    const charArray = chars.split('');
    const fontSize = 14;
    const columns = canvas.width / fontSize;

    const drops = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -100;
    }

    function draw() {
      ctx.fillStyle = 'rgba(15, 20, 25, 0.05)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      ctx.font = fontSize + 'px monospace';

      for (let i = 0; i < drops.length; i++) {
        const char = charArray[Math.floor(Math.random() * charArray.length)];
        const x = i * fontSize;
        const y = drops[i] * fontSize;
        
        const brightness = Math.random();
        if (brightness > 0.9) {
          ctx.fillStyle = '#fff';
        } else if (brightness > 0.7) {
          ctx.fillStyle = '#1d9bf0';
        } else {
          ctx.fillStyle = '#0d5c2e';
        }
        
        ctx.fillText(char, x, y);

        if (y > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
        drops[i]++;
      }
    }

    setInterval(draw, 50);

    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  }
</script>
