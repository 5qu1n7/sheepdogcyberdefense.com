---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Message Sent | Sheepdog Cyber Defense" description="Thank you for contacting Sheepdog Cyber Defense." showMatrix={true}>
  <section class="thanks">
    <h1>Message Received</h1>
    <p class="lead">Thanks for reaching out. We'll get back to you within 24 hours or next business day.</p>
    <p><a href="/">&larr; Back to Home</a></p>
  </section>
</BaseLayout>

<style>
  .thanks {
    text-align: center;
    padding: 4rem 0;
  }
  
  .lead {
    font-size: 1.25rem;
    margin-bottom: 2rem;
  }
</style>
