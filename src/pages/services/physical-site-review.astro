    "@type": "Service",
    "name": "Physical Site Review",
    "description": "Assessment of physical security including building access controls, perimeter security, video surveillance, and visitor management.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Sheepdog Cyber Defense",
      "url": "https://sheepdogcyberdefense.com"
    },
    "areaServed": {
      "@type": "State",
      "name": "Texas"
    },
    "serviceType": "Physical Security Assessment",
