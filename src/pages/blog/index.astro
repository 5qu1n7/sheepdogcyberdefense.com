---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const blogDir = new URL('../../pages/blog/', import.meta.url);
const files = fs.readdirSync(blogDir).filter(f => f.endsWith('.astro') && f !== 'index.astro');

const posts = files.map(f => {
  const content = fs.readFileSync(path.join(blogDir.pathname, f), 'utf-8');
  const titleMatch = content.match(/<h1>([^<]+)<\/h1>/);
  const descMatch = content.match(/<p>([^<]+)<\/p>/);
  const slug = f.replace('.astro', '');
  return {
    slug,
    title: titleMatch ? titleMatch[1] : slug.replace(/-/g, ' '),
    desc: descMatch ? descMatch[1].substring(0, 150) + '...' : ''
  };
});
---

<BaseLayout title="Security & Penetration Testing Blog | Sheepdog Cyber Defense" description="Expert insights on penetration testing, cybersecurity best practices, and how to protect your Texas business. Learn about costs, frequency, red teaming, and more." showMatrix={true}>
  <section>
    <h1>Security Blog</h1>
    <p class="lead">Expert insights on penetration testing, cybersecurity best practices, and protecting your Texas business. Learn from our experienced team about security assessments, compliance, and building a stronger security program.</p>
  </section>

  <section class="posts">
    {posts.map(post => (
      <article>
        <h2><a href={`/blog/${post.slug}`}>{post.title}</a></h2>
        <p>{post.desc}</p>
        <a href={`/blog/${post.slug}`} class="read-more">Read more &rarr;</a>
      </article>
    ))}
  </section>

  <section class="cta">
    <h2>Have a Security Question?</h2>
    <p>Can't find what you're looking for? Contact us to discuss your penetration testing needs.</p>
    <a href="/contact" class="btn">Get in Touch</a>
  </section>
</BaseLayout>

<style>
  .lead { 
    font-size: 1.25rem; 
    max-width: 700px; 
    margin-bottom: 2rem;
    color: var(--text-muted);
  }
  
  section { 
    margin-bottom: 3rem; 
  }
  
  .posts { 
    display: grid; 
    gap: 2rem;
  }
  
  article { 
    background: var(--bg-alt); 
    padding: 1.5rem; 
    border-radius: 8px; 
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  
  article:hover {
    border-color: var(--accent);
  }
  
  article h2 { 
    margin-top: 0; 
    font-size: 1.25rem;
  }
  
  article h2 a { 
    color: var(--text); 
    text-decoration: none;
  }
  
  article h2 a:hover { 
    color: var(--accent); 
  }
  
  article p { 
    margin-bottom: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  
  .read-more { 
    color: var(--accent); 
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .read-more:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .cta {
    background: var(--bg-alt);
    padding: 3rem 2rem;
    border-radius: 8px;
    text-align: center;
  }

  .cta h2 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .cta p {
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }
</style>