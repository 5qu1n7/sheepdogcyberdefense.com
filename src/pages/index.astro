---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sheepdog Cyber Defense | Penetration Testing Services" description="Veteran-owned penetration testing services in Bulverde, Spring Branch, and San Antonio. External PT, Internal PT, Web App PT, and Red Teaming." showMatrix={true}>
  <section class="hero">
    <div class="hero-logo-container">
      <img src="/images/logo.svg" alt="Sheepdog Cyber Defense" class="hero-logo">
    </div>
    <h1>Security Testing Done Right</h1>
    <p class="lead">We help Texas businesses find weaknesses before the bad guys do. Plainspoken advice. Thorough testing. No jargon.</p>
    <div class="cta-group">
      <a href="/contact" class="btn">Get in Touch</a>
      <a href="/services" class="btn-secondary">Our Services</a>
    </div>
  </section>

  <section class="trust-signals">
    <div class="signal">
      <span class="label">Veteran Owned</span>
      <span class="detail">Founded by military veterans</span>
    </div>
    <div class="signal">
      <span class="label">Since 2022</span>
      <span class="detail">Serving Texas businesses</span>
    </div>
    <div class="signal">
      <span class="label">Certifications</span>
      <span class="detail">CRTO, PNPT, GWAPT, eCPPTv2, PWPA, CEH</span>
    </div>
  </section>

  <section class="service-areas">
    <h2>Serving Bulverde, Spring Branch, San Antonio & Surrounding Areas</h2>
    <p>We work with businesses throughout the Texas Hill Country and Greater San Antonio region.</p>
  </section>

  <section class="services-preview">
    <h2>Our Services</h2>
    <div class="service-grid">
      <a href="/services/external-penetration-testing" class="service-card">
        <h3>External Penetration Testing</h3>
        <p>Test your external-facing systems from an attacker's perspective.</p>
      </a>
      <a href="/services/internal-penetration-testing" class="service-card">
        <h3>Internal Penetration Testing</h3>
        <p>Assess what happens after an attacker gains network access.</p>
      </a>
      <a href="/services/web-application-penetration-testing" class="service-card">
        <h3>Web Application Testing</h3>
        <p>Find vulnerabilities in your web applications and APIs.</p>
      </a>
      <a href="/services/red-teaming" class="service-card">
        <h3>Red Teaming</h3>
        <p>Realistic attack scenarios to test your team's detection and response.</p>
      </a>
      <a href="/services/physical-site-review" class="service-card">
        <h3>Physical Site Review</h3>
        <p>Assess physical security controls and facility vulnerabilities.</p>
      </a>
    </div>
    <p><a href="/services">View all services &rarr;</a></p>
  </section>

  <section class="cta">
    <h2>Ready to Test Your Security?</h2>
    <p>Drop us a line and we'll get back to you within 24 hours or next business day.</p>
    <a href="/contact" class="btn">Contact Us</a>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
  }
  
  .hero-logo-container {
    perspective: 1000px;
    margin-bottom: 1rem;
    position: relative;
    animation: screenShake 0.5s ease-out 0.6s;
    z-index: -1;
  }
  
  @keyframes screenShake {
    0%, 100% { transform: translateX(0) rotate(0); }
    10% { transform: translateX(-15px) rotate(-2deg); }
    20% { transform: translateX(12px) rotate(1.5deg); }
    30% { transform: translateX(-10px) rotate(-1deg); }
    40% { transform: translateX(8px) rotate(0.5deg); }
    50% { transform: translateX(-5px); }
    60% { transform: translateX(3px); }
  }
  
  .hero-logo-container::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: impactRing 1.5s ease-out 0.4s forwards;
    opacity: 0;
    box-shadow: 0 0 150px 75px var(--accent);
  }
  
  @keyframes impactRing {
    0% {
      width: 10px;
      height: 10px;
      opacity: 1;
      box-shadow: 0 0 200px 100px var(--accent);
    }
    20% {
      opacity: 1;
      box-shadow: 0 0 300px 150px var(--accent);
    }
    100% {
      width: 1800px;
      height: 1800px;
      opacity: 0;
    }
  }
  
  .hero-logo {
    height: 560px;
    width: auto;
    animation: logoSlam 0.8s cubic-bezier(0.17, 0.67, 0.12, 1.5) forwards;
    opacity: 0;
    transform: scale(0.01) rotate(-30deg);
    filter: brightness(2) blur(10px);
    z-index: -1;
    position: relative;
  }
  
  @keyframes logoSlam {
    0% {
      opacity: 0;
      transform: scale(0.01) rotate(-30deg);
      filter: brightness(4) blur(20px);
    }
    15% {
      opacity: 1;
    }
    40% {
      transform: scale(1.5) rotate(5deg);
      filter: brightness(3) blur(8px);
    }
    60% {
      transform: scale(0.75) rotate(-2deg);
      filter: brightness(1.5) blur(2px);
    }
    80% {
      transform: scale(1.1) rotate(1deg);
      filter: brightness(1.1) blur(0px);
    }
    95% {
      transform: scale(0.97);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
      filter: brightness(1) blur(0px);
    }
  }
  
  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s ease-out 1s backwards;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .lead {
    font-size: 1.25rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    animation: fadeInUp 0.6s ease-out 1.2s backwards;
  }
  
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    animation: fadeInUp 0.6s ease-out 1.4s backwards;
  }
  
  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--accent);
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-weight: 600;
    border: 2px solid var(--accent);
    transition: all 0.2s;
  }
  
  .btn-secondary:hover {
    background: var(--accent);
    color: white;
  }
  
  .trust-signals {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin: 2rem 0;
    flex-wrap: wrap;
  }
  
  .signal {
    text-align: center;
  }
  
  .signal .label {
    display: block;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  
  .signal .detail {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  
  .service-areas {
    text-align: center;
    padding: 2rem 0;
  }
  
  .service-areas h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .services-preview {
    padding: 2rem 0;
  }
  
  .service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 1.5rem 0;
  }
  
  .service-card {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    display: block;
    transition: border-color 0.2s;
  }
  
  .service-card:hover {
    border-color: var(--accent);
  }
  
  .service-card h3 {
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  
  .service-card p {
    margin-bottom: 0;
    font-size: 0.9rem;
  }
  
  .cta {
    text-align: center;
    padding: 4rem 0 2rem;
  }
  
  .cta p {
    margin-bottom: 1.5rem;
  }
</style>
